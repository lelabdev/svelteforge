{
	"name": "svelteforge",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev --host",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"setup": "bun run scripts/setup.ts",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:init": "bun run scripts/db-init.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^9.39.4",
		"@skeletonlabs/skeleton": "^4.15.0",
		"@skeletonlabs/skeleton-svelte": "^4.15.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.19.17",
		"better-sqlite3": "^12.9.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"pino-pretty": "^13.1.3",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.5.6",
		"@fontsource-variable/fira-code": "^5.2.7",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/manrope": "^5.2.8",
		"@fontsource-variable/space-grotesk": "^5.2.10",
		"better-auth": "^1.5.6",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"@tiptap/core": "^3.22.2",
		"@tiptap/extension-underline": "^3.22.4",
		"@tiptap/pm": "^3.22.2",
		"@tiptap/starter-kit": "^3.22.2",
		"lucide-svelte": "^0.564.0",
		"pino": "^10.3.1",
		"sveltekit-superforms": "^2.30.1",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	}
}
